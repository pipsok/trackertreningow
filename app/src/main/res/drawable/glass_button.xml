<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- stan wciśnięty -->
    <item android:state_pressed="true">
        <shape>
            <solid android:color="#55FFFFFF"/>
            <corners android:radius="24dp"/>
        </shape>
    </item>

    <!-- normalny -->
    <item>
        <shape>
            <!-- pół przezroczyste -->
            <solid android:color="#33FFFFFF"/>

            <!-- zaokrąglenie -->
            <corners android:radius="24dp"/>

            <!-- delikatna obwódka -->
            <stroke
                android:width="1dp"
                android:color="#66FFFFFF"/>
        </shape>
    </item>

</selector>